# Polymarket L1 Wallet Private Key (used to generate API keys)
PRIVATE_KEY=your_wallet_private_key

# Polymarket CLOB API Credentials (required)
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_API_PASSPHRASE=your_api_passphrase
POLYMARKET_WALLET=0xYourWalletAddressHere

# Reconnect delay in seconds after WS disconnect (default: 5)
RECONNECT_DELAY=5

# How often to refresh market subscriptions in seconds (default: 300)
MARKET_REFRESH_INTERVAL=300

# Telegram Bot Configuration (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_IDS=123456789,987654321
